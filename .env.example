# Core app
TAX_ASSISTANT_APP_NAME=Collaborative Tax Assistant
TAX_ASSISTANT_API_BASE_URL=
TAX_ASSISTANT_CORS_ALLOWED_ORIGINS=

# Database (current default path for local/dev and simple hosted demos)
TAX_ASSISTANT_DATABASE_URL=sqlite:///./data/tax_assistant.db

# File storage backend
TAX_ASSISTANT_STORAGE_BACKEND=local
TAX_ASSISTANT_STORAGE_DIR=./data/uploads
TAX_ASSISTANT_STORAGE_BUCKET=
TAX_ASSISTANT_STORAGE_PREFIX=tax-assistant
TAX_ASSISTANT_STORAGE_ENDPOINT_URL=
TAX_ASSISTANT_STORAGE_REGION=
TAX_ASSISTANT_STORAGE_ACCESS_KEY_ID=
TAX_ASSISTANT_STORAGE_SECRET_ACCESS_KEY=

# Policy tuning
TAX_ASSISTANT_RETENTION_DAYS=90
TAX_ASSISTANT_MATERIAL_CONFIDENCE_THRESHOLD=0.8
TAX_ASSISTANT_REQUIRE_ACTOR_IDENTITY=true

# Auth mode: header (default for local dev) or bearer (JWT)
TAX_ASSISTANT_AUTH_MODE=header
TAX_ASSISTANT_AUTH_JWKS_URL=
TAX_ASSISTANT_AUTH_JWT_SECRET=
TAX_ASSISTANT_AUTH_ISSUER=
TAX_ASSISTANT_AUTH_AUDIENCE=
TAX_ASSISTANT_AUTH_USER_ID_CLAIM=sub
TAX_ASSISTANT_AUTH_ROLE_CLAIM=role
TAX_ASSISTANT_AUTH_ALLOWED_ALGORITHMS=RS256,HS256

# Example hosted values:
# TAX_ASSISTANT_STORAGE_BACKEND=s3
# TAX_ASSISTANT_STORAGE_BUCKET=tax-assistant-docs
# TAX_ASSISTANT_CORS_ALLOWED_ORIGINS=https://your-ui-domain.example,https://your-railway-domain.example
# TAX_ASSISTANT_API_BASE_URL=https://your-railway-domain.example
# TAX_ASSISTANT_AUTH_MODE=bearer
# TAX_ASSISTANT_AUTH_JWKS_URL=https://your-auth-provider/.well-known/jwks.json
